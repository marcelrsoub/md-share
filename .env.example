# Set this to the Markdown notes folder you want to share from.
# This can be an Obsidian vault folder or any directory that contains .md files.
OBSIDIAN_VAULT_PATH=/path/to/your/notes

# Optional: where MD Share should store SQLite data and backups on the host.
MD_SHARE_DATA_PATH=./data

# Optional: the URLs users should see in the UI.
ADMIN_BASE_URL=http://localhost:3020
PUBLIC_BASE_URL=http://localhost:3021
